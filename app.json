{
  "expo": {
    "name": "Nirman",
    "slug": "nirman",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8F4EE"
    },
    "assetBundlePatterns": [
      "**/*"
